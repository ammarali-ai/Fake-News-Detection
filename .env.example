# Multilingual Fake News Detector — .env.example
# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored, so secrets stay local.

# HuggingFace Hub repo holding the TensorFlow SavedModel.
# When ./saved_model/ is empty, model_loader.py downloads it from here.
HF_MODEL_REPO_ID=ammarali-ai/Fake-News-Detection

# REQUIRED for this project: the model repo above is private/gated, so a
# read-scoped HF token is needed for huggingface_hub.snapshot_download() to
# pull the SavedModel at startup. Create one at:
#   https://huggingface.co/settings/tokens
# On HuggingFace Spaces, set this as a Space secret instead of a .env entry
# (Settings → Variables and secrets → New secret).
HF_TOKEN=
