# Multilingual Fake News Detector — .env.example
# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored, so secrets stay local.

# Optional. When ./saved_model/ is empty, model_loader.py uses this repo id
# to download the TensorFlow SavedModel from the HuggingFace Hub at startup.
# Format: "<hf-username>/<model-repo-name>"
HF_MODEL_REPO_ID=

# Optional. Required only if your HF model repo is private/gated. The HF
# Spaces UI lets you set this as a Space secret instead of a .env entry.
# HF_TOKEN=
