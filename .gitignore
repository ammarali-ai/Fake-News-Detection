# Multilingual Fake News Detector — .gitignore

# Python bytecode and caches
__pycache__/
*.pyc

# Virtual environment
.venv/
venv/

# Editor / harness local dirs
.claude/

# Local environment files
.env
*.env

# Build artifacts
*.egg-info/
dist/
build/

# OS junk
.DS_Store

# Logs
*.log

# Trained model — produced locally by `python train.py`, not committed.
# (Large; regenerate with train.py, or pull from the HF Hub fallback.)
saved_model/

# Generated corpus + evaluation output (rebuild with data_prep.py / evaluate.py)
data/train.csv
data/test.csv
evaluation_results.json

# Downloaded raw dataset overrides (scale-up path)
data/raw/

# NOTE: hand-authored seed data (data/seed/) IS committed — do not ignore it.
